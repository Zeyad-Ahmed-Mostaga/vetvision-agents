# ─────────────────────────────────────────────────────────────────────────────
# VetVision Unified — .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════
# REQUIRED API KEYS (both agents need these)
# ════════════════════════════════════════════════════════

# Utility LLM (query enhancement + HyDE + report content generation)
GROQ_API_KEY=your_groq_api_key_here

# Embeddings
JINA_API_KEY=your_jina_api_key_here

# Reranking
COHERE_API_KEY=your_cohere_api_key_here

# Web search
TAVILY_API_KEY=your_tavily_api_key_here

# Primary Agent LLM (OpenRouter — used by both User Agent and Vet Copilot)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Fallback Agent LLM (Google Gemini — used by User Agent only)
GOOGLE_API_KEY=your_google_api_key_here

# ════════════════════════════════════════════════════════
# OPTIONAL MODEL OVERRIDES
# ════════════════════════════════════════════════════════

# OpenRouter model for both agents
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# Gemini fallback model (User Agent only)
GEMINI_MODEL=gemini-2.0-flash

# Groq model for utility tasks and report generation (Vet Copilot)
GROQ_MODEL=llama-3.3-70b-versatile

# ════════════════════════════════════════════════════════
# VECTOR STORE — QDRANT
# ════════════════════════════════════════════════════════

# Mode: hybrid (default — tries cloud, falls back to local disk)
#       cloud  — cloud only
#       local  — local disk only
QDRANT_MODE=hybrid

# Qdrant Cloud (primary)
QDRANT_CLOUD_URL=https://your-cluster.qdrant.io
QDRANT_CLOUD_API_KEY=your_qdrant_cloud_api_key_here

# Qdrant On-Disk (fallback — relative to project root)
QDRANT_LOCAL_PATH=./data/qdrant_db

# Collection name (shared by both agents)
COLLECTION_NAME=vetvision

# ════════════════════════════════════════════════════════
# VET COPILOT — DATABASE & REPORTS
# ════════════════════════════════════════════════════════

# SQLite patient records database
SQLITE_DB_PATH=./data/patients.db

# PDF report output directory
REPORTS_DIR=./data/reports

# Jinja2 HTML template directory (contains report.html)
REPORT_TEMPLATES_DIR=./data/templates

# Arabic font directory (contains Amiri-Regular.ttf, Amiri-Bold.ttf)
REPORT_FONTS_DIR=./data/fonts

# ════════════════════════════════════════════════════════
# USER AGENT — MARKDOWN INDEXING SOURCES
# (only needed when running scripts/build_index.py)
# ════════════════════════════════════════════════════════

# Base path to the pre-parsed Markdown files
MD_BASE_PATH=C:\Users\Zeyad Ahmed\Desktop\VetVision RAG Agent\VetVision data md

# Individual file overrides (optional — defaults built from MD_BASE_PATH)
# MD_CAT=
# MD_DOG=
# MD_HORSE=
# MD_OTHER=

# ════════════════════════════════════════════════════════
# OBSERVABILITY (optional — leave blank to disable)
# ════════════════════════════════════════════════════════

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=VetVision-Unified
